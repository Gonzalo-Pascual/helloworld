pipeline {
    agent any

     stages {
        stage('Get Code') {
            steps {
                // Obtener código del repo
                git 'https://github.com/Gonzalo-Pascual/helloworld.git'
            }
        }

    stage('Tests')
    {
        parallel {

            stage('Unit') {
                steps {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                        bat '''
                                set PYTHONPATH=%WORKSPACE%
                                pytest --junitxml=result-unit.xml test\\unit
                        '''
                    }
                }
            }
            
            stage('Rest') {
                steps {
                    bat '''
                        set FLASK_APP=app\\api.py
                        set FLASK_ENV=development
                        start /B flask run
                        
                        :: Usamos comillas y dobles barras para la ruta
                        start /B java -jar "C:\\Users\\gonza\\Documents\\Trabajos\\UNIR\\wiremock-standalone-3.13.2.jar" --port 9090 --root-dir test\\wiremock
                        
                        :: Esperamos 10 segundos a que suban los servicios
                        timeout /t 10 /nobreak
                        
                        set PYTHONPATH=%WORKSPACE%
                        pytest --junitxml=result-rest.xml test\\rest
                    '''
                }    
            }
        }
    }
    
  }
}
